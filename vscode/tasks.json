{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Streamlit",
            "type": "shell",
            "command": "${workspaceFolder}/legal_env/bin/streamlit",
            "args": ["run", "main.py"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Install Requirements",
            "type": "shell",
            "command": "${workspaceFolder}/legal_env/bin/pip",
            "args": ["install", "-r", "requirements.txt"],
            "group": "build"
        },
        {
            "label": "Check Secrets",
            "type": "shell",
            "command": "./check_secrets.sh",
            "group": "test"
        },
        {
            "label": "Git Status",
            "type": "shell",
            "command": "git",
            "args": ["status"],
            "group": "test"
        }
    ]
}
